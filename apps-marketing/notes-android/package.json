{
  "name": "notes-android",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx server/src/index.ts",
    "dev": "tsx watch server/src/index.ts",
    "build:contracts": "pnpm --filter @lib/db-marketing check-types",
    "build:server": "pnpm run build:contracts && tsc --project tsconfig.json --noEmit",
    "build:android": "bash ./scripts/build-android.sh",
    "build": "pnpm run build:server && pnpm run build:android",
    "check-types": "pnpm run build:server"
  },
  "dependencies": {
    "@lib/db-marketing": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
