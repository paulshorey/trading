{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@lib/config/typescript/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./server/src/*"]
    },
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["server/src/**/*"],
  "exclude": ["node_modules"]
}
