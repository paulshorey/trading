{
  "name": "notes-next",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build:contracts": "pnpm --filter @lib/db-marketing check-types",
    "build": "pnpm run build:contracts && next build",
    "start": "next start",
    "test": "node --import tsx --test test/**/*.test.ts",
    "lint": "eslint --max-warnings 0",
    "check-types": "pnpm run build:contracts && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@lib/db-marketing": "workspace:*",
    "next": "16.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
