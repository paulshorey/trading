{
  "name": "tradingview-node",
  "version": "1.0.0",
  "description": "Express service for TradingView strength webhook and reads",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "env:pull": "node ../../scripts/fetch-infisical.mjs --app tradingview-node",
    "test": "NODE_ENV=test node --import tsx --import ./src/test/setup.ts --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lib/common": "workspace:*",
    "@lib/db-trading": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.6.0"
  }
}
