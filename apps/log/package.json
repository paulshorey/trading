{
  "name": "log",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3333",
    "build": "next build",
    "env:pull": "node ../../scripts/fetch-infisical.mjs --app log",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "lint:pretty": "npm run prettier:check && next lint",
    "lint:stylelint": "stylelint '**/*.css' --cache",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@lib/common": "workspace:*",
    "@lib/db-postgres": "workspace:*",
    "@mantine/core": "8.2.5",
    "@mantine/hooks": "8.2.5",
    "next": "^14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "sass": "^1.89.2"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.4",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.31.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-mantine": "3.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.6",
    "jest": "^30.0.5",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "3.1.1",
    "typescript": "5.8.2"
  }
}
