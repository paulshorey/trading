{
  "extends": "@my/config/ts/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@src/*": ["src/*"],
      "@my/be/*": ["../../my/be/*"]
    }
  },
  "include": ["next-env.d.ts", "next.config.mjs", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next"]
}
