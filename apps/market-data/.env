APP_NAME="market-data"
RAILPACK_INSTALL_COMMAND="pnpm --filter market-data --filter @lib/config --filter @lib/common install"

# Use specific front-month contracts (ESH6 = March 2026, NQH6 = March 2026)
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_SYMBOLS=ESH6 # ESH6,ESM6
DATABENTO_STYPE=raw_symbol

# App
PORT=8080
