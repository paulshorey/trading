{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter market-view-next build",
    "watchPatterns": ["apps/market-view-next/**"]
  },
  "deploy": {
    "startCommand": "pnpm --filter market-view-next start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
