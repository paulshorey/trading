{
  "name": "trade",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "scripts/dev-timed.sh",
    "build": "next build",
    "env:pull": "node ../../scripts/fetch-infisical.mjs /m/apps/trade apps/trade/.env",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "lint:pretty": "npm run prettier:check && next lint",
    "lint:stylelint": "stylelint '**/*.css' --cache",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "npm run typecheck && npm run jest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@lib/common": "workspace:*",
    "@dydxprotocol/v4-client-js": "1.21.1",
    "next": "^14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "sass": "^1.89.2"
  },
  "devDependencies": {
    "@lib/config": "workspace:*",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/react": "^18",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "3.1.1",
    "typescript": "5.8.2"
  }
}
