generator client {
  provider = "prisma-client-js"
  output   = "..prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  dydx_seed_public String?
  dydx_seed_secret String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Log {
  id          Int      @id @default(autoincrement())
  name        String
  message     String
  stack       Json?
  access_key  String?
  server_name String?
  app_name    String?
  node_env    String?
  category    String?
  tag         String?
  time        DateTime @default(now())

  @@map("logs_v1")
}

model Order {
  id          Int      @id @default(autoincrement())
  client_id   Int
  type        String   // "MARKET" | "LIMIT" | "STOP_MARKET"
  ticker      String
  side        String   // "LONG" | "SHORT"
  amount      Decimal
  price       Decimal
  server_name String?
  app_name    String?
  node_env    String?
  time        DateTime @default(now())

  @@map("orders_v1")
}
