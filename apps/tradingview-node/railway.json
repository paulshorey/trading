{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter tradingview-node build",
    "watchPatterns": ["apps/tradingview-node/**"]
  },
  "deploy": {
    "startCommand": "pnpm --filter tradingview-node start",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
