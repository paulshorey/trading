{
  "name": "m",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:write-node": "turbo run build --filter=write-node...",
    "db:timescale:schema:snapshot": "pnpm --filter @lib/db-timescale db:schema:snapshot",
    "db:timescale:types:generate": "pnpm --filter @lib/db-timescale db:types:generate",
    "db:timescale:migrate": "pnpm --filter @lib/db-timescale db:migrate",
    "db:timescale:verify": "pnpm --filter @lib/db-timescale db:verify",
    "db:timescale:migrate:baseline": "pnpm --filter @lib/db-timescale db:migrate:baseline",
    "db:timescale:migration:new": "pnpm --filter @lib/db-timescale db:migration:new",
    "db:timescale:sync": "pnpm --filter @lib/db-timescale db:sync",
    "db:trading:schema:snapshot": "pnpm --filter @lib/db-trading db:schema:snapshot",
    "db:trading:types:generate": "pnpm --filter @lib/db-trading db:types:generate",
    "db:trading:migrate": "pnpm --filter @lib/db-trading db:migrate",
    "db:trading:verify": "pnpm --filter @lib/db-trading db:verify",
    "db:trading:migrate:baseline": "pnpm --filter @lib/db-trading db:migrate:baseline",
    "db:trading:migration:new": "pnpm --filter @lib/db-trading db:migration:new",
    "db:trading:sync": "pnpm --filter @lib/db-trading db:sync",
    "deps:install": "bash scripts/install-workspace-deps.sh",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:write-node": "pnpm --filter write-node dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "init": "node scripts/fetch-infisical.mjs --all",
    "cloud:install": "bash scripts/cloud-agent-install.sh",
    "cloud:start": "bash scripts/cloud-agent-start.sh",
    "create:next-app": "node scripts/create-next-app.js"
  },
  "devDependencies": {
    "@infisical/sdk": "^4.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.11"
  }
}
