{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["TRADING_DB_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "env": ["TRADING_DB_URL", "TIMESCALE_DB_URL"]
    },
    "db:verify": {
      "cache": false,
      "env": ["TRADING_DB_URL", "TIMESCALE_DB_URL"]
    },
    "db:migrate-and-verify": {
      "cache": false,
      "env": ["TRADING_DB_URL", "TIMESCALE_DB_URL"]
    }
  }
}
